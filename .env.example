# =============================================================================
# WMS Tool - Environment Configuration Template
# Copy this file to .env.dev, .env.staging, or .env.prod and fill in values
# =============================================================================

# Deployment
APP_ENV=development          # development | staging | production
APP_VERSION=1.0.0            # Must match a git tag (e.g. 1.0.0, 1.1.0)
DOCKER_REGISTRY=ghcr.io/your-github-username

# Flask
DEBUG=False
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=CHANGE_ME_STRONG_SECRET_KEY_32CHARS
JWT_SECRET_KEY=CHANGE_ME_STRONG_JWT_KEY_32CHARS

# Database
DB_ENGINE=mysql+pymysql
DB_HOST=mysql_db             # Use service name in Docker, IP/hostname otherwise
DB_PORT=3306
DB_NAME=warehouse_management
DB_USERNAME=wms_user
DB_PASS=CHANGE_ME_DB_PASSWORD

# MySQL root (Docker service only)
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# Connection Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Frontend
REACT_APP_BACKEND_SERVER=http://localhost:5001/api/
